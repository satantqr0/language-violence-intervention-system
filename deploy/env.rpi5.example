# Raspberry Pi 5 deployment environment
# Copy this file to .env on the Pi and fill only the values you actually use.

VD_PROJECT_DIR=/home/pi/language-violence-intervention-system
VD_AUDIO_DIR=/home/pi/language-violence-intervention-system/audio
VD_DATA_DIR=/home/pi/language-violence-intervention-system/data
VD_SAVE_RECORDINGS=false
# Optional: ALSA playback route, for example a USB speaker such as plughw:CARD=BR17,DEV=0.
VD_AUDIO_OUTPUT_DEVICE=

# Required: credentials protecting the LAN Web management console.
VD_WEB_USERNAME=pi
VD_WEB_PASSWORD=

# Optional: enables DashScope ASR / LLM / TTS when config selects those engines.
DASHSCOPE_API_KEY=

# Optional: reserved for NLS voiceprint integration. Without these, voiceprint
# falls back to simulation mode and core detection continues.
NLS_ACCESS_KEY_ID=
NLS_ACCESS_KEY_SECRET=
NLS_APP_KEY=

# Optional: SMB upload target for saved wav files.
SMB_HOST=
SMB_PORT=445
SMB_USER=
SMB_PASS=
SMB_SHARE=
SMB_FOLDER=语音文件
SMB_CLIENT_NAME=pi-vd
SMB_SERVER_NAME=smb-server
