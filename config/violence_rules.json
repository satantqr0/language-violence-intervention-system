{
    "侮辱贬低类": {
        "keywords": [
            "笨蛋", "废物", "没用", "垃圾", "白痴", "智障", "蠢货", 
            "下贱", "卑鄙", "无耻", "丢人", "丑陋", "恶心", "讨厌",
            "你怎么这么笨", "你真没用", "废物一个", "一文不值"
        ],
        "patterns": [
            "你真.*?(笨|蠢|傻|没出息)",
            ".*?(滚|闭嘴|住嘴)",
            ".*?算.*?东西",
            ".*?(丢人|丢脸)"
        ]
    },
    "威胁恐吓类": {
        "keywords": [
            "打死", "杀了", "弄死", "滚蛋", "滚出去", "不要你", 
            "赶出去", "威胁", "小心点", "让你好看", "等着瞧"
        ],
        "patterns": [
            ".*?(小心|等着).*?(收拾|整|揍)",
            ".*?(让你|看你).*?(好过|舒服)",
            ".*?(揍|打).*?你",
            "不要你.*?(了|了|滚)"
        ]
    },
    "情感操控类": {
        "keywords": [
            "还不是", "要不是为了", "要不是因为", "我容易吗", 
            "我为了谁", "你对的起", "对不起谁", "都是你的错"
        ],
        "patterns": [
            "要不是为了.*?我",
            "都是.*?(的错|害的)",
            ".*?对得起.*?吗"
        ]
    },
    "冷暴力类": {
        "keywords": [
            "不理", "不管", "随便", "无所谓", "爱咋咋", 
            "不说话", "不吭声", "冷战", "沉默"
        ],
        "patterns": [
            ".*?(半天|多久).*?不说话",
            "(沉默|冷战).*?(几天|多久)"
        ]
    },
    "人身攻击类": {
        "keywords": [
            "神经病", "有病", "脑子有问题", "心理变态", 
            "疯子", "病态", "脑子有坑", "缺心眼"
        ],
        "patterns": [
            ".*?(脑子|神经|心理).*?(问题|有病|变态)",
            ".*?是不是.*?(有病|疯了)"
        ]
    },
    "嘲讽讽刺类": {
        "keywords": [
            "哟", "啧啧", "真是", "厉害啊", "了不起", 
            "能耐", "本事", "哟哟哟", "啧啧啧", "真行啊"
        ],
        "patterns": [
            ".*?(哟|啧).*?(厉害|能|行)",
            ".*?真是.*?(厉害|了不起|本事)"
        ]
    }
}
